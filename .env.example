# Chiave API di Google AI Studio (necessaria per Antigravity)
# Ottienila da: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Integrazione Notion (Opzionale)
NOTION_TOKEN=YOUR_NOTION_INTERNAL_INTEGRATION_TOKEN_HERE

# Integrazione Bot Telegram (Opzionale)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Configurazione Mail SMTP (Opzionale, per briefing pre-evento)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_TO=destination-email@gmail.com

# Configurazione Mail IMAP in entrata (Opzionale, per sincronizzazione automatica)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your-email@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_MAILBOX=SecondBrain

# Per configurare più account email IMAP contemporaneamente (vedi mail_accounts in settings.md):
# IMAP_PASSWORD_1=your-first-account-password
# IMAP_PASSWORD_2=your-second-account-password

# Token di sicurezza per i webhook API esterni (Notion / Google Drive, ecc.)
WEBHOOK_SECRET=your_secret_token_here
